{
  "name": "@singrum/workspace",
  "version": "1.0.0",
  "description": "Workspace interface with folders and tabs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/index.tsx --format cjs,esm --dts --minify --clean",
    "dev": "tsup src/index.ts src/index.tsx --format cjs,esm --watch --dts",
    "lint": "tsc"
  },
  "keywords": [
    "workspace",
    "react",
    "zustand",
    "tabs",
    "folder-structure",
    "notion-clone"
  ],
  "author": "singrum",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "zustand": ">=5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.0.0",
    "zustand": "^5.0.0"
  }
}
