{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    
    
    "ignoreDeprecations": "6.0", 
    "baseUrl": ".",
    
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "example"]
}